# ───────────────────────────────────────────────────────────────
# SlimTrack — Variables d'environnement
# Copie ce fichier en `.env.local` et remplis les vraies valeurs.
# ───────────────────────────────────────────────────────────────

# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Secret — jamais exposé côté client (Edge Functions / API routes uniquement)
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudinary (Dashboard → Account Details)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=slimtrack
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Web Push (VAPID) — générer avec `npx web-push generate-vapid-keys`
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@slimtrack.app

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SlimTrack
